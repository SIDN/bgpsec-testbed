diff --git a/proto/bgp/bgpsec/validate.c b/proto/bgp/bgpsec/validate.c
index f97369eb..bf60242f 100644
--- a/proto/bgp/bgpsec/validate.c
+++ b/proto/bgp/bgpsec/validate.c
@@ -239,14 +239,18 @@ int bgpsec_calculate_ski(const bgpsec_key_data key,
     int result = BGPSEC_FAILURE;
     unsigned digest_len;
 
-    if (X509_PUBKEY_set(&pubkey, key.pkey) &&
-	EVP_Digest(pubkey->public_key->data, pubkey->public_key->length,
+    if (X509_PUBKEY_set(&pubkey, key.pkey)){
+       const unsigned char *key_data;
+       int key_length;
+
+    if (EVP_Digest(key_data, key_length,
 		   digest, &digest_len, EVP_sha1(), NULL) &&
 	digest_len <= ski_len)
     {
 	memcpy(ski, digest, digest_len);
 	result = digest_len;
     }
+    }
 
     X509_PUBKEY_free(pubkey);
     return result;
